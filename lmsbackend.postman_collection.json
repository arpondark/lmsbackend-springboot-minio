{
  "info": {
    "name": "LMS Backend - Users, Courses and Reviews",
    "description": "Postman collection for User, Course and Review APIs.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080"
    },
    {
      "key": "courseId",
      "value": "1"
    },
    {
      "key": "reviewId",
      "value": "1"
    },
    {
      "key": "instructorId",
      "value": "1"
    },
    {
      "key": "userId",
      "value": "1"
    }
  ],
  "item": [
    {
      "name": "Users",
      "item": [
        {
          "name": "Create User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"john_doe\",\n  \"email\": \"john@example.com\",\n  \"password\": \"secret123\",\n  \"firstName\": \"John\",\n  \"lastName\": \"Doe\",\n  \"role\": \"USER\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/users",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "users"
              ]
            }
          }
        },
        {
          "name": "Get All Users",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/users",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "users"
              ]
            }
          }
        },
        {
          "name": "Get User By Id",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/users/{{userId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "users",
                "{{userId}}"
              ]
            }
          }
        },
        {
          "name": "Get User By Username",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/users/username/john_doe",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "users",
                "username",
                "john_doe"
              ]
            }
          }
        },
        {
          "name": "Update User",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"john_doe\",\n  \"email\": \"john.updated@example.com\",\n  \"password\": \"newsecret123\",\n  \"firstName\": \"John\",\n  \"lastName\": \"Updated\",\n  \"role\": \"INSTRUCTOR\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/users/{{userId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "users",
                "{{userId}}"
              ]
            }
          }
        },
        {
          "name": "Delete User",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{baseUrl}}/api/users/{{userId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "users",
                "{{userId}}"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Courses",
      "item": [
        {
          "name": "Create Course",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"courseName\": \"Java Spring Boot Masterclass\",\n  \"courseDescription\": \"Backend development with Spring Boot\",\n  \"imageUrl\": \"https://example.com/images/spring.jpg\",\n  \"videoUrl\": \"https://example.com/videos/intro.mp4\",\n  \"instructorId\": {{instructorId}},\n  \"price\": 49.99,\n  \"category\": \"Programming\",\n  \"level\": \"BEGINNER\",\n  \"duration\": 20\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/courses",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "courses"
              ]
            }
          }
        },
        {
          "name": "Get All Courses",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/courses",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "courses"
              ]
            }
          }
        },
        {
          "name": "Get Course By Id",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/courses/{{courseId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "courses",
                "{{courseId}}"
              ]
            }
          }
        },
        {
          "name": "Get Courses By Instructor",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/courses/instructor/{{instructorId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "courses",
                "instructor",
                "{{instructorId}}"
              ]
            }
          }
        },
        {
          "name": "Update Course",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"courseName\": \"Java Spring Boot Masterclass - Updated\",\n  \"courseDescription\": \"Updated course content\",\n  \"imageUrl\": \"https://example.com/images/spring-new.jpg\",\n  \"videoUrl\": \"https://example.com/videos/new-intro.mp4\",\n  \"instructorId\": {{instructorId}},\n  \"price\": 59.99,\n  \"category\": \"Programming\",\n  \"level\": \"INTERMEDIATE\",\n  \"duration\": 24\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/courses/{{courseId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "courses",
                "{{courseId}}"
              ]
            }
          }
        },
        {
          "name": "Delete Course",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{baseUrl}}/api/courses/{{courseId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "courses",
                "{{courseId}}"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Reviews",
      "item": [
        {
          "name": "Create Review",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": {{userId}},\n  \"courseId\": {{courseId}},\n  \"reviewText\": \"Excellent course with practical examples.\",\n  \"rating\": 5\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/reviews",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "reviews"
              ]
            }
          }
        },
        {
          "name": "Get All Reviews",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/reviews",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "reviews"
              ]
            }
          }
        },
        {
          "name": "Get Review By Id",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/reviews/{{reviewId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "reviews",
                "{{reviewId}}"
              ]
            }
          }
        },
        {
          "name": "Get Reviews By Course",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/reviews/course/{{courseId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "reviews",
                "course",
                "{{courseId}}"
              ]
            }
          }
        },
        {
          "name": "Get Reviews By User",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/reviews/user/{{userId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "reviews",
                "user",
                "{{userId}}"
              ]
            }
          }
        },
        {
          "name": "Update Review",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": {{userId}},\n  \"courseId\": {{courseId}},\n  \"reviewText\": \"Updated review text\",\n  \"rating\": 4\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/reviews/{{reviewId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "reviews",
                "{{reviewId}}"
              ]
            }
          }
        },
        {
          "name": "Delete Review",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{baseUrl}}/api/reviews/{{reviewId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "reviews",
                "{{reviewId}}"
              ]
            }
          }
        }
      ]
    }
  ]
}
